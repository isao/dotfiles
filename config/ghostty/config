# Config reference: <https://ghostty.org/docs/config/reference>
#
# Show full default configuration with docs:
#   ghostty +show-config --default --docs

#
#   Application
#

scrollback-limit = 99999999

# https://ghostty.org/docs/config/reference#macos-titlebar-style
macos-titlebar-style = tabs

macos-secure-input-indication = false

# https://ghostty.org/docs/features/shell-integration#shell-integration-injection
shell-integration-features = ssh-env,ssh-terminfo,sudo,title,no-cursor


#
#   Appearance
#

theme = light:Xcode Light hc, dark:Xcode Dark hc  # See `ghostty +list-themes`

font-family = 0xProto
font-size = 13

# font ligatures
# font-feature = -calt
# font-feature = -liga
# font-feature = -dlig

cursor-style = block
cursor-color = Light Blue
cursor-text = Dark Blue
# Color names #RRGGBB or RRGGBB or <https://en.wikipedia.org/wiki/X11_color_names>

minimum-contrast = 1.2

background-opacity = 0.9
background-blur-radius = 30

unfocused-split-opacity = 0.5
#unfocused-split-fill = ffffff

window-padding-x = 5
window-padding-balance = true

#
#   Quick Terminal
#

quick-terminal-position = top
quick-terminal-size = 35%, 45%
#quick-terminal-animation-duration = 0
keybind = global:opt+cmd+digit_1=toggle_quick_terminal
# Need this to change quick-terminal configs:
# window-save-state = never
# ^ https://github.com/ghostty-org/ghostty/discussions/8419#discussioncomment-15725026


#
#   Interaction
#

focus-follows-mouse = true

# https://ghostty.org/docs/config/reference#copy-on-select
# `copy-on-select = true` is the default, but it only copies to the "selection
# clipboard" which isn't paste-able outside Ghostty afaict.
copy-on-select = clipboard


#
#   Key bindings
#
# https://github.com/ghostty-org/ghostty/blob/485b6b73bf8007dee396ca515c5b45cddfc2f5d3/src/input/key.zig#L260

keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down
keybind = home=scroll_to_top
keybind = end=scroll_to_bottom

#   Window/pane/tab controls
keybind = cmd+shift+o=toggle_split_zoom
keybind = cmd+right=goto_split:next
keybind = cmd+left=goto_split:previous

# ghostty is eating opt+` (Raycast search files)
keybind = opt+backquote=unbind

# cmd+period -> ctrl+c
keybind = cmd+period=text:\x03

# shift+enter for Claude Code
keybind = shift+enter=text:\x1b\r
